{
  "compilerOptions": {
    /* Defaults */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "types": ["node"],
    /* Paths */
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Bundling */
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["**/*.ts", ".eslintrc.json", ],
  "exclude": ["./node_modules", "./dist", "vitest.config.ts","prisma.config.ts"]
}